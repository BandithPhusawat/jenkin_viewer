FROM node:20-alpine

WORKDIR /app

# ติดตั้ง dependencies ที่ Alpine ต้องการ
RUN apk add --no-cache libc6-compat

# Copy package files ก่อน เพื่อใช้ Docker cache
COPY package.json package-lock.json* ./

# ใช้ --legacy-peer-deps เผื่อกรณี peer deps conflict
RUN npm install --legacy-peer-deps

# Copy source (จะถูก override ด้วย volume mount ตอน dev)
COPY . .

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV WATCHPACK_POLLING=true

CMD ["npm", "run", "dev"]
